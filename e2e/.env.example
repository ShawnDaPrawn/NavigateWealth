PLAYWRIGHT_BASE_URL=http://localhost:5173

# Admin login used by sender.spec.ts. Use a dedicated test account.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Signer tokens are single-use access codes pulled from the magic-link
# emitted when an envelope is sent. Generate two so signer + decline
# specs can run in any order without colliding.
E2E_SIGNER_TOKEN=
E2E_SIGNER_DECLINE_TOKEN=
